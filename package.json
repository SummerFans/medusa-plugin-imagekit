{
  "name": "medusa-plugin-imagekit",
  "version": "0.1.0",
  "description": "Imagekit file connector for Medusa v2",
  "author": "SummerFans (https://github.com/SummerFans)",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/SummerFans/medusa-plugin-imagekit"
  },
  "files": [
    ".medusa/server"
  ],
  "exports": {
    "./package.json": "./package.json",
    "./workflows": "./.medusa/server/src/workflows/index.js",
    "./.medusa/server/src/modules/*": "./.medusa/server/src/modules/*/index.js",
    "./modules/*": "./.medusa/server/src/modules/*/index.js",
    "./providers/*": "./.medusa/server/src/providers/*/index.js",
    "./admin": {
      "import": "./.medusa/server/src/admin/index.mjs",
      "require": "./.medusa/server/src/admin/index.js",
      "default": "./.medusa/server/src/admin/index.js"
    },
    "./*": "./.medusa/server/src/*.js"
  },
  "keywords": [
    "medusa",
    "plugin",
    "medusa-plugin-other",
    "medusa-plugin",
    "medusa-v2",
    "medusa-file",
    "medusa-integration",
    "imagekit"
  ],
  "scripts": {
    "build": "medusa plugin:build",
    "dev": "medusa plugin:develop",
    "dev:srv": "medusa develop",
    "prepublishOnly": "medusa plugin:build"
  },
  "devDependencies": {
    "@swc/core": "^1.7.28",
    "@swc/jest": "^0.2.36",
    "@types/jest": "^29.5.13",
    "@types/node": "^20.12.11",
    "@types/react": "^18.3.2",
    "@types/react-dom": "^18.2.25",
    "jest": "^29.7.0",
    "prop-types": "^15.8.1",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "ts-node": "^10.9.2",
    "typescript": "^5.6.2",
    "vite": "^5.4.14",
    "yalc": "^1.0.0-pre.53"
  },
  "peerDependencies": {
    "@medusajs/admin-sdk": "^2.10.4",
    "@medusajs/cli": "^2.10.4",
    "@medusajs/framework": "^2.10.4",
    "@medusajs/test-utils": "^2.10.4",
    "@medusajs/medusa": "^2.10.4",
    "@medusajs/ui": "^4.0.3",
    "@medusajs/icons": "^2.10.4",
    "imagekit": "^6.0.0"
  },
  "engines": {
    "node": ">=20"
  }
}